  </div>
</div>

<div id="completion-overlay">
  <div id="completion-content">
    <h2>🎉 Excellent!</h2>
    <p>Excellent! You've mastered shape decomposition!</p>
    <div id="summary" style="margin-bottom:20px;text-align:left;"></div>
    <button id="btn-play-again">Play Again</button>
  </div>
